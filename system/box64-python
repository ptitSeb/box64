#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
PYTHON_SITE_DIR="$(CDPATH= cd -- "$SCRIPT_DIR/../share/box64" && pwd)"

if [[ -n "${PYTHONPATH:-}" ]]; then
    export PYTHONPATH="$PYTHON_SITE_DIR:$PYTHONPATH"
else
    export PYTHONPATH="$PYTHON_SITE_DIR"
fi

exec python3 "$@"
